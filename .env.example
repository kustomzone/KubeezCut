# ===========================================
# Frontend Configuration (Vite)
# ===========================================

# Public site URL (no trailing slash). Used for canonical, Open Graph, Twitter cards,
# JSON-LD, robots.txt, and sitemap.xml. Set to your production domain in CI (e.g. Vercel).
# VITE_PUBLIC_SITE_URL=https://editor.kubeez.com

# Show/hide floating debug button in editor (dev mode only)
# Set to 'false' to hide debug panel button during development
VITE_SHOW_DEBUG_PANEL=true

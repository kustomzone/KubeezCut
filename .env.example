# ===========================================
# Frontend Configuration (Vite)
# ===========================================

# Public site URL (no trailing slash). Used for canonical, Open Graph, Twitter cards,
# JSON-LD, robots.txt, and sitemap.xml. Set to your production domain in CI (e.g. Vercel).
# VITE_PUBLIC_SITE_URL=https://editor.kubeez.com

# Browser calls Kubeez API at this origin (skips same-origin /api/kubeez). Requires CORS on api.kubeez.com.
# Unset in dev (Vite proxy). Production + editor.kubeez.com infers https://api.kubeez.com when unset.
# Use empty value only if you must force proxy-only: VITE_KUBEEZ_BROWSER_API_URL=
# VITE_KUBEEZ_BROWSER_API_URL=https://api.kubeez.com
#
# Self-hosted: still reverse-proxy /api/kubeez-media → media.kubeez.com (CDN files are fetched same-origin).

# Show/hide floating debug button in editor (dev mode only)
# Set to 'false' to hide debug panel button during development
VITE_SHOW_DEBUG_PANEL=true
